<mvc:View
    controllerName="cryptodash.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <VBox class="sapUiSmallMargin">
        <Title text="{i18n>homeTitle}" level="H4" class="sapUiSmallMarginBottom" />
        <Text text="Updated: {crypto>/lastUpdateDisplay}" class="sapUiTinyMarginBottom sapUiSmallMarginEnd" />
        <FlexBox wrap="Wrap" renderType="Div" justifyContent="Start" alignItems="Start">
            <items>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="BTC/USDC" tooltip="Bitcoin" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                            <items>
                                <Text text="{= ${crypto>/prices/BTCUSDC} + ' | ' + ${crypto>/eurPrices/BTCUSDC} }" wrapping="false" />
                                <ObjectStatus text="{crypto>/changes/BTCUSDC}" state="{crypto>/changeStates/BTCUSDC}" />
                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
                        <core:HTML id="chartBtc" content="&lt;div style='width:100%;height:140px'&gt;&lt;canvas id='canvasBtc' style='width:100%;height:100%'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
                        <ObjectStatus text="{crypto>/errors/BTCUSDC}" state="Error" visible="{= ${crypto>/errors/BTCUSDC} !== '' }" />
                    </content>
                </Panel>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="ETH/USDC" tooltip="Ethereum" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                            <items>
                                <Text text="{= ${crypto>/prices/ETHUSDC} + ' | ' + ${crypto>/eurPrices/ETHUSDC} }" wrapping="false" />
                                <ObjectStatus text="{crypto>/changes/ETHUSDC}" state="{crypto>/changeStates/ETHUSDC}" />
                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
                        <core:HTML id="chartEth" content="&lt;div style='width:100%;height:140px'&gt;&lt;canvas id='canvasEth' style='width:100%;height:100%'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
                        <ObjectStatus text="{crypto>/errors/ETHUSDC}" state="Error" visible="{= ${crypto>/errors/ETHUSDC} !== '' }" />
                    </content>
                </Panel>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="SOL/USDC" tooltip="Solana" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                            <items>
                                <Text text="{= ${crypto>/prices/SOLUSDC} + ' | ' + ${crypto>/eurPrices/SOLUSDC} }" wrapping="false" />
                                <ObjectStatus text="{crypto>/changes/SOLUSDC}" state="{crypto>/changeStates/SOLUSDC}" />
                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
                        <core:HTML id="chartSol" content="&lt;div style='width:100%;height:140px'&gt;&lt;canvas id='canvasSol' style='width:100%;height:100%'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
                        <ObjectStatus text="{crypto>/errors/SOLUSDC}" state="Error" visible="{= ${crypto>/errors/SOLUSDC} !== '' }" />
                    </content>
                </Panel>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="XRP/USDC" tooltip="XRP" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                            <items>
                                <Text text="{= ${crypto>/prices/XRPUSDC} + ' | ' + ${crypto>/eurPrices/XRPUSDC} }" wrapping="false" />
                                <ObjectStatus text="{crypto>/changes/XRPUSDC}" state="{crypto>/changeStates/XRPUSDC}" />
                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
