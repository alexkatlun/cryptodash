                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
                        <core:HTML id="chartLink" content="&lt;div style='width:100%;height:140px'&gt;&lt;canvas id='canvasLink' style='width:100%;height:100%'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
                        <ObjectStatus text="{crypto>/errors/LINKUSDC}" state="Error" visible="{= ${crypto>/errors/LINKUSDC} !== '' }" />
                    </content>
                </Panel>
            </items>
        </FlexBox>
    </VBox>
</mvc:View>
