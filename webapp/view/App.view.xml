                                <ObjectStatus text="{crypto>/changes/POLUSDC}" state="{crypto>/changeStates/POLUSDC}" />
                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
                        <core:HTML id="chartPol" content="&lt;div style='width:100%;height:140px'&gt;&lt;canvas id='canvasPol' style='width:100%;height:100%'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
                        <ObjectStatus text="{crypto>/errors/POLUSDC}" state="Error" visible="{= ${crypto>/errors/POLUSDC} !== '' }" />
                    </content>
                </Panel>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="AVAX/USDC" tooltip="Avalanche" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                            <items>
                                <Text text="{= ${crypto>/prices/AVAXUSDC} + ' | ' + ${crypto>/eurPrices/AVAXUSDC} }" wrapping="false" />
                                <ObjectStatus text="{crypto>/changes/AVAXUSDC}" state="{crypto>/changeStates/AVAXUSDC}" />
                            </items>
                        </HBox>
                        <Text text="Intraday" class="sapUiTinyMarginBottom" />
                        <core:HTML id="chartAvax" content="&lt;div style='width:100%;height:140px'&gt;&lt;canvas id='canvasAvax' style='width:100%;height:100%'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
                        <ObjectStatus text="{crypto>/errors/AVAXUSDC}" state="Error" visible="{= ${crypto>/errors/AVAXUSDC} !== '' }" />
                    </content>
                </Panel>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="LINK/USDC" tooltip="Chainlink" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                            <items>
                                <Text text="{= ${crypto>/prices/LINKUSDC} + ' | ' + ${crypto>/eurPrices/LINKUSDC} }" wrapping="false" />
