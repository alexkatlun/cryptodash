                        <ObjectStatus text="{crypto>/errors/XRPUSDC}" state="Error" visible="{= ${crypto>/errors/XRPUSDC} !== '' }" />
                    </content>
                </Panel>
                <Panel width="17rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="POL/USDC" tooltip="Polygon Ecosystem Token" level="H6" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <HBox width="100%" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
